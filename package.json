{
  "name": "suqnaa",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev:api": "pnpm --dir apps/api dev",
    "dev:web": "pnpm --dir apps/web dev",
    "build:api": "pnpm --filter suqnaa-api build",
    "build:web": "pnpm --filter suqnaa-web build",
    "build": "pnpm build:api && pnpm build:web",
    "typecheck": "pnpm -r typecheck",
    "test:api": "pnpm --filter suqnaa-api test:security",
    "test:web": "pnpm --filter suqnaa-web test:session",
    "test": "pnpm test:api && pnpm test:web",
    "ci": "pnpm typecheck && pnpm test"
  }
}
