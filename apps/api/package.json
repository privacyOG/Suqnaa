{
  "name": "suqnaa-api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:security": "tsx src/security/human-protection.test.ts && tsx src/security/risk-policy.test.ts && tsx src/security/turnstile-verifier.test.ts"
  },
  "dependencies": {
    "argon2": "0.41.1",
    "dotenv": "16.4.7",
    "fastify": "5.2.1",
    "kysely": "0.27.5",
    "pg": "8.13.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/pg": "8.11.10",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  },
  "private": true
}
