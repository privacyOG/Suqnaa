# Runtime
NODE_ENV=development

# API service
API_HOST=0.0.0.0
API_PORT=4000
WEB_ORIGIN=http://localhost:3000

# Web-to-API URLs
# NEXT_PUBLIC_API_BASE_URL is used by browser-side requests.
# API_BASE_URL is used by server-side web routes when available.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_BASE_URL=http://localhost:4000

# Data stores
DATABASE_URL=postgres://suqnaa:suqnaa_dev_password@localhost:5432/suqnaa
REDIS_URL=redis://localhost:6379

# Security secrets - replace with long random production values and keep out of source control.
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-secret
PASSWORD_PEPPER=replace-with-a-long-random-secret

# Object storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=suqnaa-local
S3_ACCESS_KEY=suqnaa
S3_SECRET_KEY=suqnaa_dev_password

# Human challenge provider
CHALLENGE_PROVIDER=none
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_EXPECTED_HOSTNAME=
TURNSTILE_TIMEOUT_MS=5000
NEXT_PUBLIC_CHALLENGE_SCRIPT_URL=

# Signed payment-provider events - disabled until a provider and compliance controls are approved.
PAYMENT_EVENT_PROVIDER=none
PAYMENT_EVENT_SIGNING_SECRET=
PAYMENT_EVENT_MAX_AGE_SECONDS=300

# Assistant integration
ASSISTANT_ENABLED=false
ASSISTANT_PROVIDER=none
ASSISTANT_BASE_URL=
ASSISTANT_API_KEY=
